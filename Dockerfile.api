# Cloud Run-ready Dockerfile for data-pipeline's FastAPI layer (pipeline/api.py)
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
 && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

ENV PORT=8080
EXPOSE 8080

CMD exec uvicorn pipeline.api:app --host 0.0.0.0 --port ${PORT}
